rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════
// Reglas de seguridad de Firestore para RenovaBase (proyecto Firebase: renova-bdonl)
//
// CÓMO DESPLEGAR (requiere Firebase CLI instalado y sesión iniciada):
//   1. npm install -g firebase-tools        (si no lo tienes)
//   2. firebase login
//   3. firebase use --add                    -> selecciona el proyecto "renova-bdonl"
//      (o crea firebase.json/.firebaserc apuntando a "renova-bdonl" si no existen)
//   4. firebase deploy --only firestore:rules
//
// Estas reglas NO se despliegan solas: hay que correr el paso 4 manualmente.
// ══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function estaLogueado() {
      return request.auth != null;
    }

    // Perfil del usuario autenticado (colección "usuarios", doc id = uid de Firebase Auth)
    function miPerfil() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function miRol() {
      return miPerfil().rol;
    }

    function esAdminOCoordinador() {
      return estaLogueado() && miRol() in ['admin', 'coordinador'];
    }

    // El nombre de usuario (campo "usuario" del doc en /usuarios) del que llama,
    // usado para comparar contra lead.abeja (que guarda ese mismo string, no el uid).
    function miUsuario() {
      return miPerfil().usuario;
    }

    // ── usuarios ──
    // Cualquier usuario autenticado puede LEER la colección completa (se necesita
    // para poblar dropdowns de asignación de leads, ver getListaAbejas() en el front).
    // Solo admin puede escribir perfiles de otros usuarios (crear/editar/activar-desactivar).
    // Un usuario puede editar su propio doc SOLO para campos no sensibles (ver docs
    // de negocio: hoy el front no permite auto-editar rol/activo, solo password vía
    // Firebase Auth, que no pasa por Firestore).
    match /usuarios/{uid} {
      allow read: if estaLogueado();
      allow create, update, delete: if estaLogueado() && miRol() == 'admin';
    }

    // ── leads ──
    // admin / coordinador: acceso total (ver, asignar a cualquier abeja, editar cualquier campo).
    // abeja (vendedor): solo puede LEER y EDITAR los leads que tiene asignados
    // (lead.abeja === su propio "usuario"). No puede reasignar el lead a otra abeja
    // ni crear/eliminar leads (eso lo hace el conector Sheet -> Firestore o un admin).
    match /leads/{leadId} {
      allow read: if estaLogueado() && (
        esAdminOCoordinador() || resource.data.abeja == miUsuario()
      );
      allow create, delete: if estaLogueado() && esAdminOCoordinador();
      allow update: if estaLogueado() && (
        esAdminOCoordinador() ||
        (
          resource.data.abeja == miUsuario() &&
          // Una abeja no puede reasignar el lead a otra persona
          request.resource.data.abeja == resource.data.abeja
        )
      );
    }

    // ── contadores auxiliares (p.ej. contadores/leads para asignar "fila" numérico
    // secuencial a nuevos leads importados desde el Sheet) ──
    match /contadores/{id} {
      allow read: if estaLogueado();
      allow write: if estaLogueado() && esAdminOCoordinador();
    }

    // Cualquier otra colección: denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
