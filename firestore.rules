rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════
// Reglas de seguridad de Firestore para RenovaBase (proyecto Firebase: renova-bdonl)
//
// Modelo simplificado: la autenticación de Firestore NO valida rol (admin /
// coordinador / abeja). Solo exige que el usuario esté logueado en Firebase
// Auth. El control de qué puede ver/editar cada rol vive ÚNICAMENTE en el
// front-end (index.html, USUARIOS_HARDCODED + SESSION.rol), no aquí.
//
// Los usuarios base (los que ya existían en la pestaña "Usuarios" del Sheet)
// están hardcodeados en el front (USUARIOS_HARDCODED) y NO tienen doc en
// Firestore. Los usuarios que se agreguen después desde la app (addUsuario)
// SÍ se guardan en la colección "usuarios" de Firestore.
//
// CÓMO DESPLEGAR (requiere Firebase CLI instalado y sesión iniciada):
//   1. npm install -g firebase-tools        (si no lo tienes)
//   2. firebase login
//   3. firebase use --add                    -> selecciona el proyecto "renova-bdonl"
//   4. firebase deploy --only firestore:rules
// ══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogueado() {
      return request.auth != null;
    }

    // ── usuarios: solo usuarios nuevos agregados desde la app viven aquí ──
    match /usuarios/{uid} {
      allow read, write: if estaLogueado();
    }

    // ── leads ──
    match /leads/{leadId} {
      allow read, write: if estaLogueado();
    }

    // ── contadores auxiliares ──
    match /contadores/{id} {
      allow read, write: if estaLogueado();
    }

    // Cualquier otra colección: denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
